# Contact form (Resend) — copy to .env.local and fill in.
# 1. Create an account at https://resend.com and add + verify your sending domain (DNS records).
# 2. Create an API key.
RESEND_API_KEY=

# Verified sender, e.g. "EGY-KEN Builders <quotes@egyken.co.ke>"
# Until your domain is verified you can test with: EGY-KEN Website <onboarding@resend.dev>
RESEND_FROM=

# Where enquiries are delivered (defaults to the site email if unset).
CONTACT_TO=Egyken.builders04@gmail.com
